---
type Experience = {
  organization: string;
  title: string;
  period: string;
  startDate: string;
  endDate: string;
  lane: number;
  location: string;
  summary: string;
};

interface Props {
  items: readonly Experience[];
}

const { items } = Astro.props;
const timelineStart = new Date("2020-01-01").getTime();
const timelineEnd = new Date("2026-06-30").getTime();
const range = timelineEnd - timelineStart;
const yearMarkers = ["2020", "2021", "2022", "2023", "2024", "2025", "2026"];
const laneHeight = 105;
const timelineHeight = 410;
const accents = ["#0369a1", "#2563eb", "#0891b2", "#4f46e5", "#0f766e"];

const positionFor = (date: string) => {
  const value = new Date(date).getTime();
  return Math.min(100, Math.max(0, ((value - timelineStart) / range) * 100));
};

const positionedItems = items
  .map((item, index) => {
    const start = positionFor(item.startDate);
    const end = positionFor(item.endDate);
    return {
      ...item,
      index,
      start,
      width: Math.max(3, end - start),
      top: 120 + item.lane * laneHeight,
      color: accents[index % accents.length],
      labelSide: start > 68 ? "left" : "right",
      labelPosition:
        item.organization === "Telstra" || item.title === "Doctoral Researcher" ? "above" : "below",
    };
  })
  .sort((a, b) => new Date(a.startDate).getTime() - new Date(b.startDate).getTime());
---

<div class="mt-12 rounded-lg border border-slate-200 bg-white/88 p-4 shadow-lg shadow-sky-100/70 sm:p-6">
  <div class="pb-2">
    <div class="relative w-full" style={`height: ${timelineHeight}px;`} data-experience-stage>
      <div class="absolute left-0 right-0 top-8 h-px bg-slate-200"></div>
      {
        yearMarkers.map((year) => {
          const left = positionFor(`${year}-01-01`);
          return (
            <div class="absolute top-0" style={`left: ${left}%;`}>
              <div class="h-8 w-px bg-slate-200"></div>
              <p class="-translate-x-1/2 font-mono text-xs font-semibold text-slate-500">{year}</p>
            </div>
          );
        })
      }

      {
        positionedItems.map((item) => (
          <>
            <div
              class="absolute h-1.5 min-w-5 rounded-full"
              style={`left: ${item.start}%; top: ${item.top}px; width: ${item.width}%; background: linear-gradient(90deg, ${item.color}, ${item.color}88);`}
              aria-hidden="true"
            />

            <div class="absolute" style={`left: ${item.start}%; top: ${item.top}px;`}>
              <span
                class:list={[
                  "absolute left-0 z-0 h-4 w-px -translate-x-1/2 bg-slate-200",
                  item.labelPosition === "above" ? "bottom-4" : "top-4",
                ]}
                aria-hidden="true"
              />
              <button
                type="button"
                class="group absolute left-0 top-0 z-10 h-8 w-8 -translate-x-1/2 -translate-y-1/2"
                data-experience-trigger
                data-experience-index={item.index}
                aria-label={`Open details for ${item.title} at ${item.organization}`}
              >
                <span
                  class="absolute left-1/2 top-1/2 block h-7 w-7 -translate-x-1/2 -translate-y-1/2 rounded-full border-4 border-white shadow-md shadow-sky-100 ring-1 ring-slate-200 transition group-hover:scale-110 group-focus-visible:scale-110"
                  style={`background-color: ${item.color};`}
                  aria-hidden="true"
                />
              </button>

              <button
                type="button"
                class:list={[
                  "group absolute z-10 w-max rounded-md border border-slate-200 bg-white/95 px-3 py-2 text-left shadow-sm shadow-sky-100 transition hover:border-sky-300 hover:text-sky-800",
                  item.labelSide === "left" ? "right-6 text-right" : "left-6",
                  item.labelPosition === "above" ? "bottom-7" : "top-7",
                ]}
                data-experience-trigger
                data-experience-index={item.index}
                aria-label={`Open details for ${item.title} at ${item.organization}`}
              >
                <span class="block whitespace-nowrap text-xs font-semibold leading-5 text-slate-950 sm:text-sm">{item.title}</span>
                <span class="mt-1 block whitespace-nowrap text-xs font-medium leading-4 text-slate-500">{item.organization}</span>
              </button>
            </div>
          </>
        ))
      }

      <div
        class="absolute z-40 hidden w-[min(24rem,calc(100%-1rem))] rounded-lg border border-slate-200 bg-white p-5 text-slate-950 shadow-2xl shadow-slate-300/40"
        data-experience-popover
        role="dialog"
        aria-label="Experience details"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-sky-700" data-dialog-period></p>
            <h3 class="mt-3 text-xl font-semibold tracking-tight text-slate-950" data-dialog-title></h3>
            <p class="mt-1 text-sm font-semibold text-sky-700" data-dialog-organization></p>
          </div>
          <button
            type="button"
            class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-slate-200 text-slate-500 transition hover:border-sky-300 hover:text-sky-800"
            data-popover-close
            aria-label="Close experience details"
          >
            <svg aria-hidden="true" class="h-4 w-4" viewBox="0 0 24 24" fill="none">
              <path d="M6 6l12 12M18 6 6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
            </svg>
          </button>
        </div>
        <p class="mt-4 text-sm font-medium text-slate-500" data-dialog-location></p>
        <p class="mt-3 text-sm leading-7 text-slate-600" data-dialog-summary></p>
      </div>
    </div>
  </div>

  <p class="mt-4 text-sm text-slate-500">Select a dot or role label to view details.</p>
</div>

<script is:inline define:vars={{ experiences: positionedItems }}>
  const stage = document.querySelector("[data-experience-stage]");
  const popover = document.querySelector("[data-experience-popover]");
  const closeButton = popover?.querySelector("[data-popover-close]");
  const fields = {
    period: popover?.querySelector("[data-dialog-period]"),
    title: popover?.querySelector("[data-dialog-title]"),
    organization: popover?.querySelector("[data-dialog-organization]"),
    location: popover?.querySelector("[data-dialog-location]"),
    summary: popover?.querySelector("[data-dialog-summary]"),
  };

  const setText = (node, value) => {
    if (node) node.textContent = value;
  };

  const closePopover = () => {
    popover?.classList.add("hidden");
  };

  const positionPopover = (trigger) => {
    if (!stage || !popover) return;

    const stageRect = stage.getBoundingClientRect();
    const triggerRect = trigger.getBoundingClientRect();

    popover.classList.remove("hidden");
    popover.style.visibility = "hidden";
    popover.style.left = "0px";
    popover.style.top = "0px";

    const popoverRect = popover.getBoundingClientRect();
    const gap = 14;
    const padding = 8;
    const triggerCenterX = triggerRect.left - stageRect.left + triggerRect.width / 2;

    let left =
      triggerCenterX > stageRect.width * 0.58
        ? triggerCenterX - popoverRect.width - gap
        : triggerCenterX + gap;
    left = Math.max(padding, Math.min(left, stageRect.width - popoverRect.width - padding));

    let top = triggerRect.bottom - stageRect.top + gap;
    if (top + popoverRect.height > stageRect.height - padding) {
      top = triggerRect.top - stageRect.top - popoverRect.height - gap;
    }
    top = Math.max(padding, Math.min(top, stageRect.height - popoverRect.height - padding));

    popover.style.left = `${left}px`;
    popover.style.top = `${top}px`;
    popover.style.visibility = "visible";
  };

  document.querySelectorAll("[data-experience-trigger]").forEach((trigger) => {
    trigger.addEventListener("click", (event) => {
      event.stopPropagation();
      const item = experiences.find((experience) => experience.index === Number(trigger.dataset.experienceIndex));
      if (!item || !popover) return;

      setText(fields.period, item.period);
      setText(fields.title, item.title);
      setText(fields.organization, item.organization);
      setText(fields.location, item.location);
      setText(fields.summary, item.summary);
      positionPopover(trigger);
    });
  });

  closeButton?.addEventListener("click", closePopover);
  document.addEventListener("click", (event) => {
    if (!popover || popover.classList.contains("hidden")) return;
    if (popover.contains(event.target) || event.target.closest("[data-experience-trigger]")) return;
    closePopover();
  });
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape") closePopover();
  });
</script>
