---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="max-w-3xl">
  {
    eyebrow && (
      <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">
        {eyebrow}
      </p>
    )
  }
  <h2 class="text-3xl font-semibold tracking-tight text-slate-950 sm:text-4xl">{title}</h2>
  {description && <p class="mt-4 text-base leading-7 text-slate-600 sm:text-lg">{description}</p>}
</div>
