---
import Badge from "./Badge.astro";
import { credibility, heroStats, site } from "../data/site";
---

<section id="top" class="relative isolate overflow-hidden border-b border-slate-200/90 bg-gradient-to-br from-white via-sky-50/70 to-blue-50/80">
  <div class="technical-grid absolute inset-0 -z-10 opacity-80" aria-hidden="true"></div>
  <div class="absolute left-1/2 top-8 -z-10 h-80 w-80 -translate-x-1/2 rounded-full bg-sky-200/55 blur-3xl" aria-hidden="true"></div>

  <div class="site-shell grid min-h-[calc(100svh-4rem)] items-center gap-10 py-14 sm:py-[4.5rem] lg:grid-cols-[minmax(0,1fr)_21rem] lg:py-20 xl:grid-cols-[minmax(0,1fr)_23rem]">
    <div class="max-w-4xl">
      <p class="font-mono text-xs font-semibold uppercase tracking-[0.2em] text-sky-700">
        {site.positioning}
      </p>
      <h1 class="mt-5 text-4xl font-semibold tracking-tight text-slate-950 sm:text-5xl lg:whitespace-nowrap xl:text-[3.45rem]">
        {site.name}
      </h1>
      <p class="mt-5 text-lg font-medium text-slate-700 sm:text-xl">{site.role}</p>
      <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">{site.hero}</p>

      <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
        <a class="rounded-md bg-sky-600 px-5 py-3 text-center text-sm font-semibold text-white shadow-sm shadow-sky-200 transition hover:bg-sky-700" href="#work">
          View Work
        </a>
        <a class="rounded-md border border-sky-300 bg-white/70 px-5 py-3 text-center text-sm font-semibold text-sky-800 transition hover:border-sky-500 hover:bg-sky-50" href={site.cvUrl} download>
          Download CV
        </a>
        <a class="rounded-md border border-slate-300 bg-white/70 px-5 py-3 text-center text-sm font-semibold text-slate-700 transition hover:border-sky-400 hover:text-sky-800" href={site.links.linkedin}>
          LinkedIn
        </a>
        <a class="rounded-md border border-slate-300 bg-white/70 px-5 py-3 text-center text-sm font-semibold text-slate-700 transition hover:border-sky-400 hover:text-sky-800" href={site.links.email}>
          Email
        </a>
        <a class="rounded-md border border-slate-300 bg-white/70 px-5 py-3 text-center text-sm font-semibold text-slate-700 transition hover:border-sky-400 hover:text-sky-800" href={site.links.github}>
          GitHub
        </a>
      </div>

      <div class="mt-8 flex flex-wrap gap-2" aria-label="Professional credibility">
        {credibility.map((item) => <Badge text={item} />)}
      </div>
    </div>

    <aside class="mx-auto w-full max-w-[18rem] lg:ml-auto lg:max-w-none" aria-label="Profile summary">
      <div class="rounded-lg border border-slate-200 bg-white/82 p-3 shadow-2xl shadow-sky-100/80">
        <div class="overflow-hidden rounded-md border border-slate-200 bg-slate-50 shadow-sm shadow-sky-100/80">
          <img
            src={site.profileImage}
            alt="Portrait of Dilantha Haputhanthri"
            width="1254"
            height="1254"
            loading="eager"
            decoding="async"
            class="aspect-square w-full object-cover object-center"
          />
        </div>
      </div>

      <div class="mt-4 grid grid-cols-3 gap-2 text-center">
        {
          heroStats.map((stat) => (
            <div class="rounded-md border border-slate-200 bg-white/90 p-3 shadow-sm shadow-sky-100/70">
              <p class="text-xl font-semibold text-sky-700">{stat.value}</p>
              <p class="mt-1 text-xs text-slate-500">{stat.label}</p>
            </div>
          ))
        }
      </div>

      <div class="mt-4 rounded-lg border border-sky-100 bg-sky-50/75 p-4">
        <p class="font-mono text-xs uppercase tracking-[0.16em] text-slate-500">Current focus</p>
        <p class="mt-2 text-sm font-semibold leading-6 text-slate-800">
          Azure-native AI architecture, Multi-agent Workflows, AI Security, and Enterprise Automation.
        </p>
      </div>
    </aside>
  </div>
</section>
