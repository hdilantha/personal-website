---
import Badge from "./Badge.astro";

interface Props {
  title: string;
  role: string;
  description: string;
  tags: readonly string[];
  relatedPosts?: readonly {
    title: string;
    href: string;
  }[];
  relatedPublications?: readonly {
    title: string;
    href: string;
  }[];
}

const { title, role, description, tags, relatedPosts, relatedPublications } = Astro.props;
---

<article
  class="rounded-lg border border-slate-200 bg-white/94 p-6 shadow-lg shadow-sky-100/70 transition duration-200 hover:border-sky-300"
>
  <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">{role}</p>
  <h3 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950">{title}</h3>
  <p class="mt-4 text-sm leading-7 text-slate-600">{description}</p>
  <div class="mt-6 flex flex-wrap gap-2" aria-label={`${title} technology tags`}>
    {tags.map((tag) => <Badge text={tag} />)}
  </div>
  {
    relatedPosts && relatedPosts.length > 0 && (
      <div class="mt-6 border-t border-slate-200 pt-5">
        <h4 class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">
          Related writing
        </h4>
        <div class="mt-3 space-y-2">
          {relatedPosts.map((post) => (
            <a
              class="block rounded-md border border-sky-200 bg-sky-50/80 px-4 py-3 text-sm font-semibold leading-6 text-slate-950 transition hover:border-sky-300 hover:bg-sky-100/80 hover:text-sky-800"
              href={post.href}
            >
              {post.title}
            </a>
          ))}
        </div>
      </div>
    )
  }
  {
    relatedPublications && relatedPublications.length > 0 && (
      <div class="mt-6 border-t border-slate-200 pt-5">
        <h4 class="font-mono text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">
          Related publications
        </h4>
        <div class="mt-3 space-y-2">
          {relatedPublications.map((publication) => (
            <a
              class="block rounded-md border border-emerald-200 bg-emerald-50/80 px-4 py-3 text-sm font-semibold leading-6 text-slate-950 transition hover:border-emerald-300 hover:bg-emerald-100/80 hover:text-emerald-800"
              href={publication.href}
              target="_blank"
              rel="noreferrer"
            >
              {publication.title}
            </a>
          ))}
        </div>
      </div>
    )
  }
</article>
