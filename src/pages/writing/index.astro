---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import Badge from "../../components/Badge.astro";
import Footer from "../../components/Footer.astro";
import { site, writingPlaceholders } from "../../data/site";

const posts = (await getCollection("writing"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => {
    const aDate = a.data.published?.getTime() ?? 0;
    const bDate = b.data.published?.getTime() ?? 0;
    return bDate - aDate;
  });

const formatDate = (date?: Date) =>
  date?.toLocaleDateString("en-AU", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
---

<BaseLayout
  title={`Writing | ${site.name}`}
  description="Notes and essays by Dilantha Haputhanthri on production AI, Azure architecture, RAG, agentic workflows, and energy-efficient AI."
>
  <Navbar />
  <main>
    <section class="border-b border-slate-200/90 bg-[#eef7ff] py-20 sm:py-24">
      <div class="site-shell">
        <div class="grid gap-10 lg:grid-cols-[0.82fr_1.18fr] lg:items-end">
          <SectionHeading
            eyebrow="Writing"
            title="Notes on applied AI, Azure architecture, and research-to-production practice."
            description="A dedicated space for technical writing, architecture notes, and practical reflections from AI research and enterprise delivery."
          />
          <div class="rounded-lg border border-slate-200 bg-white/88 p-6 shadow-lg shadow-sky-100/70">
            <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Focus Areas</p>
            <div class="mt-5 flex flex-wrap gap-2">
              <Badge text="Production AI" />
              <Badge text="Azure AI" />
              <Badge text="Enterprise RAG" />
              <Badge text="Agentic Workflows" />
              <Badge text="LLM Evaluation" />
              <Badge text="Sparse AI" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="border-b border-slate-200/90 bg-white py-16 sm:py-20">
      <div class="site-shell">
        {
          posts.length > 0 ? (
            <div class="grid gap-5 md:grid-cols-2">
              {posts.map((post) => (
                <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm shadow-sky-100/70 transition hover:border-sky-300 hover:shadow-md hover:shadow-sky-100">
                  <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-sky-700">
                    {formatDate(post.data.published) ?? "Published"}
                  </p>
                  <h2 class="mt-4 text-xl font-semibold tracking-tight text-slate-950">{post.data.title}</h2>
                  <p class="mt-4 text-sm leading-7 text-slate-600">{post.data.description}</p>
                </article>
              ))}
            </div>
          ) : (
            <div>
              <div class="max-w-3xl">
                <p class="font-mono text-xs font-semibold uppercase tracking-[0.18em] text-sky-700">Draft Queue</p>
                <h2 class="mt-3 text-2xl font-semibold tracking-tight text-slate-950 sm:text-3xl">
                  Planned essays and technical notes
                </h2>
                <p class="mt-4 text-base leading-7 text-slate-600">
                  These are placeholder topics for future posts. Real articles can be added as Markdown or MDX files under
                  <span class="font-mono text-sm text-slate-800"> src/content/writing</span>.
                </p>
              </div>
              <div class="mt-10 grid gap-4 md:grid-cols-2">
                {writingPlaceholders.map((post) => (
                  <article class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm shadow-sky-100/70 transition hover:border-sky-300">
                    <p class="font-mono text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Draft placeholder</p>
                    <h3 class="mt-3 text-lg font-semibold text-slate-950">{post}</h3>
                  </article>
                ))}
              </div>
            </div>
          )
        }
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
